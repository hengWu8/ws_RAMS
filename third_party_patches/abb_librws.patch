+bool isRedirectStatus(const HTTPResponse::HTTPStatus status)
+{
+  return status == HTTPResponse::HTTP_MOVED_PERMANENTLY ||
+         status == HTTPResponse::HTTP_FOUND ||
+         status == HTTPResponse::HTTP_TEMPORARY_REDIRECT ||
+         status == HTTPResponse::HTTP_PERMANENT_REDIRECT;
+}
+
+std::string normalizeRedirectURI(const std::string& location)
+{
+  if (location.empty())
+  {
+    return location;
+  }
+
+  if (location.rfind("http://", 0) == 0 || location.rfind("https://", 0) == 0)
+  {
+    try
+    {
+      return Poco::URI(location).getPathEtc();
+    }
+    catch (...)
+    {
+      return location;
+    }
+  }
+
+  return location;
+}
+}  // namespace
+
